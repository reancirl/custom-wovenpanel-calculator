{% liquid
  assign target_product = product

  if target_product != blank
    assign enable_sqm_pricing_raw = target_product.metafields.custom.enable_sqm_pricing.value
    assign enable_sqm_pricing = false
    if enable_sqm_pricing_raw == true or enable_sqm_pricing_raw == 'true'
      assign enable_sqm_pricing = true
    endif

    if enable_sqm_pricing
      assign min_length = target_product.metafields.custom.min_length.value | default: 0.1
      assign max_length = target_product.metafields.custom.max_length.value | default: 100
      assign min_width = target_product.metafields.custom.min_width.value | default: 0.1
      assign max_width = target_product.metafields.custom.max_width.value | default: 100
      assign initial_variant = target_product.selected_or_first_available_variant
      assign initial_unit_price = initial_variant.price | divided_by: 100.0
    endif
  endif
%}

{% if target_product != blank and enable_sqm_pricing %}
  <div
    class="sqm-pricing-block"
    data-sqm-pricing
    data-enabled="true"
    data-unit-price="{{ initial_unit_price | default: 0 }}"
    data-min-length="{{ min_length }}"
    data-max-length="{{ max_length }}"
    data-min-width="{{ min_width }}"
    data-max-width="{{ max_width }}"
    data-currency="{{ cart.currency.iso_code | default: shop.currency }}"
    data-locale="{{ request.locale.iso_code | default: shop.locale | replace: '_', '-' }}"
  >
    <div class="sqm-pricing-block__field-grid">
      <label class="sqm-pricing-block__field">
        <span>Length (mm)</span>
        <input
          type="number"
          inputmode="decimal"
          min="{{ min_length | times: 1000.0 }}"
          max="{{ max_length | times: 1000.0 }}"
          step="0.01"
          data-sqm-length
          placeholder="{{ min_length | times: 1000.0 }}"
          required
        >
      </label>

      <label class="sqm-pricing-block__field">
        <span>Width (mm)</span>
        <input
          type="number"
          inputmode="decimal"
          min="{{ min_width | times: 1000.0 }}"
          max="{{ max_width | times: 1000.0 }}"
          step="0.01"
          data-sqm-width
          placeholder="{{ min_width | times: 1000.0 }}"
          required
        >
      </label>
    </div>

    <p class="sqm-pricing-block__error" data-sqm-error role="alert" aria-live="polite"></p>

    <div class="sqm-pricing-block__summary">
      <p>
        Area:
        <strong><span data-sqm-area>0</span> sqm</strong>
      </p>
      <p>
        Total price:
        <strong data-sqm-total>{{ 0 | money }}</strong>
      </p>
    </div>

    <script type="application/json" data-sqm-variant-prices>
      {
        {% for variant in target_product.variants %}
          "{{ variant.id }}": {{ variant.price | divided_by: 100.0 }}{% unless forloop.last %},{% endunless %}
        {% endfor %}
      }
    </script>
  </div>
{% elsif request.design_mode %}
  <div class="sqm-pricing-block">
    <p class="sqm-pricing-block__message">
      SQM calculator is hidden on this product because
      <code>custom.enable_sqm_pricing</code> is not enabled.
    </p>
  </div>
{% endif %}

{% schema %}
{
  "name": "SQM pricing",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "stylesheet": "sqm-pricing.css",
  "javascript": "sqm-pricing.js",
  "settings": []
}
{% endschema %}
